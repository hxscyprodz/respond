{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "types": ["react", "react-native", "node"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"]
}
